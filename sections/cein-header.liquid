<header class="site-header">
  <div class="header-container">
    <!-- LEFT: MAIN MENU -->
    <nav class="main-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {% for link in section.settings.menu.links %}
          <li class="nav-item {% if link.links != blank %}has-dropdown{% endif %}">
            <a href="{{ link.url }}">{{ link.title }}</a>

            {% if link.links != blank %}
              <div class="dropdown-menu">
                <div class="dropdown-container">
                  {% for child in link.links %}
                    <div class="dropdown-column">
                      <h4>{{ child.title }}</h4>

                      {% if child.links != blank %}
                        <ul>
                          {% for sublink in child.links %}
                            <li>
                              <a href="{{ sublink.url }}">{{ sublink.title }}</a>
                            </li>
                          {% endfor %}
                        </ul>
                      {% endif %}
                    </div>
                  {% endfor %}

                  {% if section.settings.submenu_image != blank %}
                    <div class="dropdown-image">
                      {{ section.settings.submenu_image | image_url: width: 300 | image_tag }}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>

    <!-- CENTER: LOGO -->
    <div class="logo">
      <a href="{{ routes.root_url }}">
        {% if section.settings.logo_image != blank %}
          {{ section.settings.logo_image | image_url: width: 86, height: 20 | image_tag }}
        {% endif %}
      </a>
    </div>
    <div class="cein-icons">
      <!-- SEARCH -->
      <div class="search-container">
        <button class="search-button" aria-label="{{ section.settings.search_label }}">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g clip-path="url(#clip0_4039_232)">
            <path d="M6.41667 11.0833C8.994 11.0833 11.0833 8.994 11.0833 6.41667C11.0833 3.83934 8.994 1.75 6.41667 1.75C3.83934 1.75 1.75 3.83934 1.75 6.41667C1.75 8.994 3.83934 11.0833 6.41667 11.0833Z" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12.2499 12.25L9.7124 9.71252" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
            </g>
            <defs>
            <clipPath id="clip0_4039_232">
            <rect width="14" height="14" fill="white"/>
            </clipPath>
            </defs>
          </svg>
        </button>
      </div>
      <!-- WISHLIST -->
      <a href="/pages/wishlist" class="icon">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g clip-path="url(#clip0_4039_247)">
          <path d="M7 11.8125C7 11.8125 1.3125 8.75 1.3125 5.14062C1.3125 4.35741 1.62363 3.60627 2.17745 3.05245C2.73127 2.49863 3.48241 2.1875 4.26562 2.1875C5.50102 2.1875 6.55922 2.8607 7 3.9375C7.44078 2.8607 8.49898 2.1875 9.73438 2.1875C10.5176 2.1875 11.2687 2.49863 11.8225 3.05245C12.3764 3.60627 12.6875 4.35741 12.6875 5.14062C12.6875 8.75 7 11.8125 7 11.8125Z" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
          <defs>
          <clipPath id="clip0_4039_247">
          <rect width="14" height="14" fill="white"/>
          </clipPath>
          </defs>
        </svg>
        <span class="wishlist-count">{{ section.settings.wishlist_count }}</span>
      </a>

      <!-- ACCOUNT -->
      {% if customer %}
        <a href="{{ routes.account_url }}" class="icon">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g clip-path="url(#clip0_4039_253)">
            <path d="M11.6666 12.25V11.0833C11.6666 10.4645 11.4208 9.871 10.9832 9.43342C10.5456 8.99583 9.95209 8.75 9.33325 8.75H4.66659C4.04775 8.75 3.45425 8.99583 3.01667 9.43342C2.57908 9.871 2.33325 10.4645 2.33325 11.0833V12.25" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M7.00008 6.41667C8.28875 6.41667 9.33341 5.372 9.33341 4.08333C9.33341 2.79467 8.28875 1.75 7.00008 1.75C5.71142 1.75 4.66675 2.79467 4.66675 4.08333C4.66675 5.372 5.71142 6.41667 7.00008 6.41667Z" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
            </g>
            <defs>
            <clipPath id="clip0_4039_253">
            <rect width="14" height="14" fill="white"/>
            </clipPath>
            </defs>
          </svg>
        </a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="icon">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g clip-path="url(#clip0_4039_253)">
            <path d="M11.6666 12.25V11.0833C11.6666 10.4645 11.4208 9.871 10.9832 9.43342C10.5456 8.99583 9.95209 8.75 9.33325 8.75H4.66659C4.04775 8.75 3.45425 8.99583 3.01667 9.43342C2.57908 9.871 2.33325 10.4645 2.33325 11.0833V12.25" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M7.00008 6.41667C8.28875 6.41667 9.33341 5.372 9.33341 4.08333C9.33341 2.79467 8.28875 1.75 7.00008 1.75C5.71142 1.75 4.66675 2.79467 4.66675 4.08333C4.66675 5.372 5.71142 6.41667 7.00008 6.41667Z" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
            </g>
            <defs>
            <clipPath id="clip0_4039_253">
            <rect width="14" height="14" fill="white"/>
            </clipPath>
            </defs>
          </svg>
        </a>
      {% endif %}

      <!-- CART -->
      <a href="/cart" class="icon cart">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g clip-path="url(#clip0_4039_261)">
          <path d="M11.8125 3.9375H2.1875C1.94588 3.9375 1.75 4.13338 1.75 4.375V10.9375C1.75 11.1791 1.94588 11.375 2.1875 11.375H11.8125C12.0541 11.375 12.25 11.1791 12.25 10.9375V4.375C12.25 4.13338 12.0541 3.9375 11.8125 3.9375Z" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M4.8125 5.25V3.5C4.8125 2.91984 5.04297 2.36344 5.4532 1.9532C5.86344 1.54297 6.41984 1.3125 7 1.3125C7.58016 1.3125 8.13656 1.54297 8.5468 1.9532C8.95703 2.36344 9.1875 2.91984 9.1875 3.5V5.25" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
          <defs>
          <clipPath id="clip0_4039_261">
          <rect width="14" height="14" fill="white"/>
          </clipPath>
          </defs>
        </svg>
        <span class="cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>
{% schema %}
{
  "name": "CEIN Header Menu",
  "class": "header-cein-menu",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Menu"
    },

    {
      "type": "link_list",
      "id": "account_menu",
      "label": "Customer Account Menu (cein-customer-account-main-menu)"
    },

    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },

    {
      "type": "image_picker",
      "id": "submenu_image",
      "label": "Dropdown Image"
    },

    {
      "type": "url",
      "id": "wishlist_url",
      "label": "Wishlist Page URL"
    },

    {
      "type": "text",
      "id": "wishlist_label",
      "label": "Wishlist Label",
      "default": "Wishlist"
    },

    {
      "type": "text",
      "id": "wishlist_count",
      "label": "Wishlist Count",
      "default": "0"
    },

    {
      "type": "text",
      "id": "search_label",
      "label": "Search Label",
      "default": "Search"
    },

    {
      "type": "text",
      "id": "profile_label",
      "label": "Profile Label",
      "default": "Profile"
    },
    {
      "type": "url",
      "id": "profile_url",
      "label": "Profile URL"
    },
    {
      "type": "url",
      "id": "order_url",
      "label": "Order History URL"
    }
  ],

  "presets": [
    {
      "name": "CEIN Header Menu"
    }
  ]
}
{% endschema %}
