<header class="site-header">
  <div class="header-container">
    <!-- LEFT: MAIN MENU -->
    <nav class="main-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {% for link in section.settings.menu.links %}
          <li class="nav-item {% if link.links != blank %}has-dropdown{% endif %}">
            <a href="{{ link.url }}">{{ link.title }}</a>

            {% if link.links != blank %}
              <div class="dropdown-menu">
                <div class="dropdown-container">
                  {% for child in link.links %}
                    <div class="dropdown-column">
                      <h4>{{ child.title }}</h4>
                      {% if child.links != blank %}
                        <ul>
                          {% for sublink in child.links %}
                            <li>
                              <a href="{{ sublink.url }}">{{ sublink.title }}</a>
                            </li>
                          {% endfor %}
                        </ul>
                      {% endif %}
                    </div>
                  {% endfor %}

                  {% if section.settings.submenu_image != blank %}
                    <div class="dropdown-image">
                      {{ section.settings.submenu_image | image_url: width: 300 | image_tag }}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>

    <!-- CENTER: LOGO -->
    <div class="logo">
      <a href="{{ routes.root_url }}">
        {% if section.settings.logo_image != blank %}
          {{ section.settings.logo_image | image_url: width: 86, height: 20 | image_tag }}
        {% endif %}
      </a>
    </div>
    <!-- RIGHT: ACCOUNT & WISHLIST -->
    <div class="header-right">
      <!-- SEARCH (separate block) -->
      <div class="header-search">
        <button class="search-button" aria-label="Search">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M6.41667 11.0833C8.994 11.0833 11.0833 8.994 11.0833 6.41667C11.0833 3.83934 8.994 1.75 6.41667 1.75C3.83934 1.75 1.75 3.83934 1.75 6.41667C1.75 8.994 3.83934 11.0833 6.41667 11.0833Z" stroke="#333"/>
            <path d="M12.25 12.25L9.7125 9.7125" stroke="#333"/>
          </svg>
        </button>
      </div>
<nav class="header-actions" aria-label="Customer actions">
  <ul class="header-actions__list">

    {% for link in section.settings.account_menu.links %}

      {% if link.title contains 'Wishlist' %}
        <li class="header-actions__item">
          <a href="{{ link.url }}" class="icon" aria-label="Wishlist">
            {{ link.title }}
            <span class="count">{{ section.settings.wishlist_count }}</span>
          </a>
        </li>
      {% endif %}

      {% if link.title contains 'Profile' and customer %}
        <li class="header-actions__item">
          <a href="{{ link.url }}" class="icon" aria-label="Account">
            <span class="profile-icon"></span>
          </a>
        </li>
      {% endif %}

      {% if link.title contains 'Orders' %}
        <li class="header-actions__item">
          <a href="{{ link.url }}" class="icon" aria-label="Order History">
            <span class="order-icon"></span>
          </a>
        </li>
      {% endif %}

    {% endfor %}

  </ul>
</nav>
    </div>
  </div>
</header>
{% schema %}
{
  "name": "CEIN Header Menu",
  "class": "header-cein-menu",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Menu"
    },
    {
      "type": "link_list",
      "id": "account_menu",
      "label": "Customer Account Menu"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "image_picker",
      "id": "submenu_image",
      "label": "Dropdown Image"
    },
    {
      "type": "text",
      "id": "wishlist_count",
      "label": "Wishlist Count",
      "default": "0"
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Search Label",
      "default": "Search"
    }
  ],

  "presets": [
    {
      "name": "CEIN Header Menu",
      "category": "Header"
    }
  ]
}
{% endschema %}
