<header class="site-header">
  <div class="header-container">
    <!-- Left Navigation -->
    <nav class="main-nav">
      <ul class="nav-list">
        {% for link in section.settings.menu.links %}
        <li class="nav-item {% if link.links != blank %}has-dropdown{% endif %}">
          <!-- Main Menu -->
          <a href="{{ link.url }}">{{ link.title }}</a>
          <!-- Dropdown -->
          {% if link.links != blank %}
          <div class="dropdown-menu">
            <div class="dropdown-container">
              {% for child in link.links %}
              <div class="dropdown-column">
                <!-- Column Title -->
                <h4>{{ child.title }}</h4>
                <!-- Submenu -->
                <ul>
                  {% for sublink in child.links %}
                  <li>
                    <a href="{{ sublink.url }}">{{ sublink.title }}</a>
                  </li>
                  {% endfor %}
                </ul>

              </div>
              {% endfor %}

              <!-- Image -->
              {% if section.settings.submenu_image != blank %}
              <div class="dropdown-image">
                {{ section.settings.submenu_image | image_url: width: 300 | image_tag }}
              </div>
              {% endif %}

            </div>
          </div>
          {% endif %}

        </li>
        {% endfor %}

      </ul>
    </nav>

    <!-- Logo -->
    <div class="logo">
      <a href="{{ routes.root_url }}">
        {{ section.settings.logo_image | image_url: width: 120 | image_tag }}
      </a>
    </div>

    <!-- Right Icons -->
    <div class="header-actions">
      <a href="#" class="icon search"></a>

      <a href="#" class="lang">
        {{ section.settings.language_selector | upcase }}
      </a>

      <a href="#" class="icon wishlist">
        <span>{{ section.settings.wishlist_count }}</span>
      </a>

      <a href="#" class="icon account"></a>

      <a href="#" class="icon cart">
        <span>{{ section.settings.cart_count }}</span>
      </a>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "CEIN Header Menu",
  "class": "header-cein-menu",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Menu"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "image_picker",
      "id": "submenu_image",
      "label": "Dropdown Image"
    },
    {
      "type": "text",
      "id": "wishlist_count",
      "label": "Wishlist Count",
      "default": "0"
    },
    {
      "type": "text",
      "id": "cart_count",
      "label": "Cart Count",
      "default": "0"
    },
    {
      "type": "select",
      "id": "language_selector",
      "label": "Language",
      "options": [
        { "value": "en", "label": "English" },
        { "value": "fr", "label": "French" },
        { "value": "es", "label": "Spanish" }
      ],
      "default": "en"
    }
  ],
  "presets": [
    {
      "name": "CEIN Header Menu"
    }
  ]
}
{% endschema %}