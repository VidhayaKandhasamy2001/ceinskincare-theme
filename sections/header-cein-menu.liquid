<header class="site-header">
  <div class="header-container">
    <!-- Left Navigation -->
    <nav class="main-nav">
      <ul class="nav-list">
        {% for link in section.settings.menu.links %}
          {{ link.title }}
        <li class="nav-item has-dropdown">
          <a href="{{ link.url }}">{{ link.title }}</a>
          <div class="dropdown-menu">
            <div class="dropdown-container">
              <div class="dropdown-column">
                <h4>Submenu Title</h4>
                <ul>
                  {% for sublink in link.links %}
                  <li><a href="{{ sublink.url }}">{{ sublink.title }}</a></li>
                  {% endfor %}
                </ul>
              </div>

              <div class="dropdown-image">
               {{ section.settings.submenu_image | image_url: 'medium' | image_tag}}
              </div>
            </div>
          </div>
        </li>
        {% endfor %}
        <li class="nav-item">
          <a href="#">Menu</a>
        </li>

        <li class="nav-item">
          <a href="#">Menu</a>
        </li>
      </ul>
    </nav>

    <!-- Logo -->
    <div class="logo">
      <a href="{{ routes.root_url }}">
        {{ section.settings.logo_image | image_url: 'medium' | image_tag }}
      </a>
    </div>

    <!-- Right Icons -->
    <div class="header-actions">
      <a href="#" class="icon search"></a>

      <a href="#" class="lang">EN</a>

      <a href="#" class="icon wishlist">
        <span>0</span>
      </a>

      <a href="#" class="icon account"></a>

      <a href="#" class="icon cart">
        <span>0</span>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "CEIN Header Menu",
  "class": "header-cein-menu",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "wishlist_count",
      "label": "Wishlist Count",
      "default": "0"
    },
    {
      "type": "text",
      "id": "cart_count",
      "label": "Cart Count",
      "default": "0"
    },
    {
      "type": "select",
      "id": "language_selector",
      "label": "Language",
      "options": [
        { "value": "en", "label": "English" },
        { "value": "fr", "label": "French" },
        { "value": "es", "label": "Spanish" }
      ],
      "default": "en"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Select Submenu"
    },
    {
      "type": "image_picker",
      "id": "submenu_image",
      "label": "Dropdown Image"
    }
  ],
  "presets": [
    {
      "name": "CEIN Header Menu"
    }
  ]
}
{% endschema %}
