<header class="site-header">
  <div class="header-container">
    <nav class="main-nav">
      <ul class="nav-list">
        {% for block in section.blocks %}
        <li class="nav-item"{% if block.settings.show_dropdown %}has-dropdown{% endif %}>
          <a href="{{ block.settings.menu_link }}">
            {{ block.settings.menu_title }}
          </a>
          {% if block.settings.show_dropdown %}
          <div class="dropdown-menu">
            <div class="dropdown-container">
              {% assign menu = block.settings.submenu_menu %}
              <div class="dropdown-column">
                <h4>{{ block.settings.submenu_title }}</h4>
                <ul>
                  {% for link in menu.links %}
                    <li>
                      <a href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              </div>

              {% if block.settings.submenu_image != blank %}
              <div class="dropdown-image">
                {{ block.settings.submenu_image | image_url:width: 100, height: 100 | image_tag }}
              </div>
              {% endif %}

            </div>
          </div>
          {% endif %}

        </li>
        {% endfor %}

      </ul>
    </nav>

    <!-- Logo -->
    <div class="logo">
      {% if section.settings.logo_image != blank %}
        <a href="/">
          {{ section.settings.logo_image | image_url:width: 100, height: 100 | image_tag }}
        </a>
      {% endif %}
    </div>

    <!-- Right Icons -->
    <div class="header-actions">
      <a href="#" class="icon search"></a>

      <a href="#" class="lang">
        {{ section.settings.language_selector | upcase }}
      </a>

      <a href="#" class="icon wishlist">
        <span>{{ section.settings.wishlist_count }}</span>
      </a>

      <a href="#" class="icon account"></a>

      <a href="#" class="icon cart">
        <span>{{ section.settings.cart_count }}</span>
      </a>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "CEIN Header Menu",
  "class": "header-cein-menu",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "wishlist_count",
      "label": "Wishlist Count",
      "default": "0"
    },
    {
      "type": "text",
      "id": "cart_count",
      "label": "Cart Count",
      "default": "0"
    },
    {
      "type": "select",
      "id": "language_selector",
      "label": "Language",
      "options": [
        { "value": "en", "label": "English" },
        { "value": "fr", "label": "French" },
        { "value": "es", "label": "Spanish" }
      ],
      "default": "en"
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu Item",
      "settings": [
        {
          "type": "text",
          "id": "menu_title",
          "label": "Menu Title"
        },
        {
          "type": "url",
          "id": "menu_link",
          "label": "Menu Link"
        },
        {
          "type": "checkbox",
          "id": "show_dropdown",
          "label": "Enable Dropdown",
          "default": true
        },
        {
          "type": "text",
          "id": "submenu_title",
          "label": "Submenu Title"
        },
        {
          "type": "link_list",
          "id": "submenu_menu",
          "label": "Select Submenu"
        },
        {
          "type": "image_picker",
          "id": "submenu_image",
          "label": "Dropdown Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CEIN Header Menu",
      "blocks": [
        {
          "type": "menu_item"
        },
        {
          "type": "menu_item"
        }
      ]
    }
  ]
}
{% endschema %}